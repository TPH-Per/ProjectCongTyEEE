# ============================================================
# NGƯU CÁT POS — Environment variables TEMPLATE
#
# ⚠️ File này CHỈ chứa PLACEHOLDER, KHÔNG chứa key thật.
#    Để chạy local:
#      1. cp .env.example .env.local
#      2. Mở .env.local, thay các giá trị <...> bằng giá trị thật
#         từ Supabase Dashboard → Settings → API
#      3. File .env.local đã có trong .gitignore, KHÔNG bị commit
#
# ⚠️ KHÔNG commit giá trị thật lên git. Kể cả publishable key
#    cũng KHÔNG NÊN commit vào example file — chỉ dùng placeholder.
# ============================================================

# ----- Supabase Project -----
# Project URL, dạng: https://<project-ref>.supabase.co (KHÔNG có /rest/v1/)
# Lấy từ Supabase Dashboard → Settings → API → Project URL
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Anon / publishable key — KEY NÀY ĐƯỢC PHÉP xuất hiện ở client
# (RLS bảo vệ data), nhưng KHÔNG NÊN commit key thật lên git.
# Lấy từ Supabase Dashboard → Settings → API → "anon public" key
#   - Project cũ:   bắt đầu bằng "eyJhbGciOi..."
#   - Project mới (2025+): dạng "sb_publishable_xxx"
VITE_SUPABASE_PUBLISHABLE_KEY=<your-publishable-or-anon-key>

# Alias fallback cho setup cũ (optional — bỏ trống nếu dùng key ở trên)
# VITE_SUPABASE_ANON_KEY=

# ----- App config -----
# Locale mặc định: vi | ja | en
VITE_DEFAULT_LOCALE=vi

# Bật log chi tiết của Supabase client (true | false)
VITE_SUPABASE_DEBUG=false

# ============================================================
# KHÔNG ĐẶT CÁC BIẾN SAU Ở ĐÂY (chỉ dành cho backend):
#   - SUPABASE_SERVICE_ROLE_KEY  (full DB access, bypass RLS)
#   - DATABASE_URL               (direct connection string)
#   - VT_API_KEY, PRINT_AGENT_URL, KDS_WS_URL  (Edge Function secrets)
#
# Set các secret trên qua CLI:
#   supabase secrets set KEY=value
# ============================================================

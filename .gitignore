# Dependencies
node_modules/

# Production build output
dist/
dist-ssr/
*.local

# Environment files — never commit real secrets
.env
.env.local
.env.*.local

# Supabase CLI temp/cache (auto-generated, never commit)
supabase/.temp/
supabase/.branches/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor configurations
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvsca
*.njsproj
*.sln
*.sw?

# Stray one-off refactor scripts dropped at the project root.
# We keep the historical copies under scripts/_archive/per-onetime/.
# New root-level .py files are almost always a smell — if you need a
# bulk-edit, use a shell loop, the Node REPL, or a properly namespaced
# script under scripts/.
/*.py

# IDE swap files (KDE Kate, vim, etc.)
*.kate-swp
*.swp
*.swo

# Ignore local SQL dumps at root
/*.sql

# Playwright test artifacts (auto-generated on every `npx playwright test`)
/playwright-report/
/test-results/
/playwright/.cache/

# TypeScript incremental build cache (auto-generated by `vue-tsc -b`)
*.tsbuildinfo

flowchart TD
    classDef process fill:#e1f5fe,stroke:#01579b,stroke-width:2px;
    classDef decision fill:#fff9c4,stroke:#fbc02d,stroke-width:2px;
    classDef grill fill:#ffccbc,stroke:#d84315,stroke-width:2px;
    classDef warning fill:#ffcdd2,stroke:#c62828,stroke-width:2px;

    subgraph "CHUẨN BỊ (Preparation)"
        A1["Nhận Ticket đã xác nhận"] --> A2["Lấy nguyên liệu<br/>(Áp dụng FIFO - Nhập trước xuất trước)"]
        A2 --> A3["Sơ chế / Tẩm ướp<br/>(Marination)"]
    end

    subgraph "CHẾ BIẾN (Cooking Process)"
        A3 --> B1{"Khu vực chế biến?"}
        
        %% NHÁNH BẾP NƯỚNG (GRILL)
        B1 -- "Bếp Nướng (Grill)" --> C1["Nướng trên than/lửa<br/>(Canh độ chín theo yêu cầu)"]
        C1 --> C2{"Kiểm tra Vỉ nướng & Than?"}
        
        C2 -- "Vỉ bẩn / Than yếu" --> C3["Yêu cầu thay vỉ / Châm than<br/>(Grill Change Request)"]
        C3 --> C4["Thực hiện thay vỉ<br/>(Mất ~2-3 phút)"]
        C4 --> C1
        
        C2 -- "Ổn định" --> C5["Trở mặt / Cắt thịt<br/>(Nếu cần)"]
        C5 --> C6["Trình bày món (Plating)"]

        %% NHÁNH BẾP KHÁC
        B1 -- "Bếp Lẩu (Hotpot)" --> D1["Chuẩn bị nước dùng<br/>& Rau củ"]
        D1 --> D2["Trình bày Set lẩu"]
        
        B1 -- "Bếp Lạnh/Chiên" --> E1["Chế biến theo Recipe"]
        E1 --> E2["Trình bày món"]
    end

    subgraph "HOÀN TẤT CHẾ BIẾN"
        C6 --> F1["Đặt món lên khu vực Pass<br/>(Khu vực ra món chung)"]
        D2 --> F1
        E2 --> F1
    end

    class A1,A2,A3,C1,C3,C4,C5,C6,D1,D2,E1,E2,F1 process;
    class B1,C2 decision;
    class C1,C2,C3,C4,C5,C6 grill;
    class C3 warning;
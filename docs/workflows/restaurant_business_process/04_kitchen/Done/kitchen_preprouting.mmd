flowchart TD
    classDef process fill:#e1f5fe,stroke:#01579b,stroke-width:2px;
    classDef decision fill:#fff9c4,stroke:#fbc02d,stroke-width:2px;
    classDef priority fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px;
    classDef alert fill:#ffcdd2,stroke:#c62828,stroke-width:2px;

    subgraph "PRE-SHIFT: Sơ chế đầu ngày (Prep List)"
        P1["Bếp trưởng xem Prep List<br/>(Dựa trên Booking + Lịch sử)"] --> P2["Phân công sơ chế<br/>(Thái thịt, ướp, cắt rau)"]
        P2 --> P3["Kiểm tra nhiệt độ tủ lạnh<br/>(Tủ mát ≤ 5°C, Tủ đông ≤ -18°C)"]
        P3 --> P4["Sẵn sàng đón Order"]
    end

    subgraph "ORDER RECEIVING: Tiếp nhận & Điều phối KDS"
        O1["Nhận Ticket mới từ KDS<br/>(POS / Tablet / Delivery)"] --> O2{"Loại Order?"}
        
        O2 -- "Khách Trả món (Remake)" --> O3["CẢNH BÁO: Ưu tiên CAO NHẤT<br/>(Bỏ qua hàng đợi)"]
        O2 -- "Buffet Vòng 1" --> O4["Đánh dấu: Round 1"]
        O2 -- "Buffet Gọi thêm" --> O5["Đánh dấu: Round N"]
        O2 -- "A La Carte / Set" --> O6["Xử lý đơn lẻ"]

        O3 --> R1
        O4 --> R1
        O5 --> R1
        O6 --> R1{"Định tuyến tự động<br/>(Auto-Routing)"}
    end

    subgraph "STATION ROUTING: Phân về trạm"
        R1 -- "Món Nướng" --> S1["Station: Bếp Nướng<br/>(Grill Station)"]
        R1 -- "Món Lẩu/Súp" --> S2["Station: Bếp Lẩu<br/>(Hotpot Station)"]
        R1 -- "Món Lạnh/Khai vị" --> S3["Station: Bếp Lạnh<br/>(Cold Station)"]
        R1 -- "Món Chiên/Rán" --> S4["Station: Bếp Chiên<br/>(Fry Station)"]
    end

    subgraph "ACKNOWLEDGE: Xác nhận"
        S1 --> A1["Đầu bếp xác nhận<br/>(Acknowledge Ticket)"]
        S2 --> A1
        S3 --> A1
        S4 --> A1
        A1 --> A2["Cập nhật trạng thái:<br/>'Đang chế biến' (In Progress)"]
    end

    class P1,P2,P3,P4,O1,O4,O5,O6,R1,S1,S2,S3,S4,A1,A2 process;
    class O2,R1 decision;
    class O3 priority;
    class O3 alert;
flowchart TD
    classDef process fill:#e1f5fe,stroke:#01579b,stroke-width:2px;
    classDef decision fill:#fff9c4,stroke:#fbc02d,stroke-width:2px;
    classDef warning fill:#ffcdd2,stroke:#c62828,stroke-width:2px;

    subgraph "END-OF-SHIFT: Kết thúc ca & Bàn giao"
        H1["Ca làm việc sắp kết thúc"] --> H2["Dừng nhận Order mới<br/>(Trừ khách đang ăn dở)"]
        H2 --> H3["Vệ sinh khu vực chế biến<br/>(Checklist vệ sinh cuối ca)"]
        H3 --> H4["Tắt thiết bị điện<br/>(Bếp nướng, lò chiên, máy xay)"]
    end

    subgraph "INVENTORY & SAFETY: Tồn kho bếp & An toàn"
        H4 --> I1["Kiểm kê tồn kho tại bếp<br/>(Đếm thịt, rau củ còn lại)"]
        I1 --> I2{"Chênh lệch so với<br/>lý thuyết có lớn không?"}
        
        I2 -- "Có (Mất mát/Hao hụt lớn)" --> I3["Ghi nhận Waste Log<br/>& Báo cáo Quản lý ngay"]
        I2 -- "Không (Bình thường)" --> I4["Nhập liệu tồn kho<br/>vào hệ thống POS"]
        
        I3 --> I5["Kiểm tra hạn sử dụng<br/>(FEFO - Hết hạn trước xuất trước)"]
        I4 --> I5
        
        I5 --> I6["Bọc màng co, dán nhãn<br/>ngày tháng & cất vào tủ"]
        I6 --> I7["Ghi nhận nhiệt độ tủ lạnh<br/>(Tủ mát & Tủ đông)"]
    end

    subgraph "HANDOVER: Bàn giao ca sau"
        I7 --> J1["Viết sổ giao ca / Notes trên KDS<br/>(Ghi chú món hết, sự cố, yêu cầu đặc biệt)"]
        J1 --> J2["Bếp trưởng ca sau<br/>ký xác nhận bàn giao"]
        J2 --> J3["Hoàn tất đóng cửa bếp"]
    end

    class H1,H2,H3,H4,I1,I3,I4,I5,I6,I7,J1,J2,J3 process;
    class I2 decision;
    class I3 warning;